@model UserRegisterViewModel

<h1>Register User</h1>

<form asp-route="saveUserRegister" method="post">
    <label asp-for="@Model.Username"></label>
    <input asp-for="@Model.Username">
    
    <label asp-for="@Model.Password"></label>
    <input type="password" asp-for="@Model.Password">

    <label asp-for="@Model.ConfirmPassword"></label>
    <input type="password" asp-for="@Model.ConfirmPassword">

    <label asp-for="@Model.FirstName"></label>
    <input asp-for="@Model.FirstName">

    <label asp-for="@Model.LastName"></label>
    <input asp-for="@Model.LastName">

    <label asp-for="@Model.Email"></label>
    <input asp-for="@Model.Email">

    <input type="submit">
    <a asp-action="index">Cancel</a>
</form>