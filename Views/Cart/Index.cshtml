@model GridViewModel<CartViewModel>

<div>
    <h1>Cart List</h1>
</div>

<div>
    <a asp-controller="home">Back to Home</a>
</div>

<div>
    <form>
        <input type="hidden" name="pageNumber" asp-for="@Model.Pagination.PageNumber">
        <label asp-for="@Model.Pagination.PageSize">Rows</label>
        <select name="pageSize" asp-for="@Model.Pagination.PageSize" asp-items="@Model.Pagination.PageSizeDropdown"></select>
        <input type="submit">
    </form>
</div>

<div>
    <table>
        <thead>
            <tr>
                <th>Product Name</th>
                <th>Quantity</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cart in Model.Content) {
                <tr>
                    <td>@cart.ProductName</td>
                    <td>@cart.Quantity</td>
                    <td>
                        <a asp-action="upsert" asp-route-id="@cart.Id">Edit</a>
                        <a asp-action="delete" asp-route-id="@cart.Id">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <td colspan="2">
                    @for(int i = 1; i <= Model.Pagination.TotalPages; i++) {
                        <a asp-route-pageNumber="@i" asp-route-pageSize="@Model.Pagination.PageSize">@i</a>
                    }
                </td>
            </tr>
        </tfoot>
    </table>
</div>
